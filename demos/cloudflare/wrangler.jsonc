{
  "name": "my-emdash-site",
  "compatibility_date": "2026-04-04",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "my-emdash-site",
      "database_id": "*************"
    }
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "my-emdash-media"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "****************"
    }
  ]
}
